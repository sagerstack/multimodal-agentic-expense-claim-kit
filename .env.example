# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agentic_claims
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# Chainlit Configuration
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000

# Application Environment
APP_ENV=local

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL_LLM=qwen/qwq-32b
OPENROUTER_MODEL_VLM=google/gemini-2.0-flash-001
OPENROUTER_FALLBACK_MODEL_LLM=google/gemini-2.0-flash-lite-001
OPENROUTER_FALLBACK_MODEL_VLM=google/gemini-2.0-flash-lite-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_DELAY=2.0
OPENROUTER_VLM_MAX_TOKENS=4096
OPENROUTER_LLM_MAX_TOKENS=8192
OPENROUTER_LLM_TEMPERATURE=0.3

# Qdrant Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# SMTP Configuration (for email MCP server)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# MCP Server URLs (internal Docker network)
RAG_MCP_URL=http://mcp-rag:8000/mcp/
DB_MCP_URL=http://mcp-db:8000/mcp/
CURRENCY_MCP_URL=http://mcp-currency:8000/mcp/
EMAIL_MCP_URL=http://mcp-email:8000/mcp/

# Image Quality Settings
IMAGE_QUALITY_THRESHOLD=150.0
IMAGE_MIN_WIDTH=800
IMAGE_MIN_HEIGHT=600

# VLM Confidence Threshold
VLM_CONFIDENCE_THRESHOLD=0.7

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=
SEQ_URL=http://localhost:5341
SEQ_PASSWORD=dev
SEQ_INGESTION_URL=http://seq/api/events/raw
